# Database Configuration
# Using port 5433 for Docker Postgres (host mapping)
# Force 127.0.0.1 to avoid localhost IPv6 issues
DATABASE_URL=postgresql://admin:password123@127.0.0.1:5433/cuin_db
DB_POOL_SIZE=5

# Neo4j Configuration
# Using default 7687/7474
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

# Redis Configuration
REDIS_URL=redis://127.0.0.1:6380/0

# App Settings
LOG_LEVEL=INFO
DEBUG=True
