# ============================================
# CUIN v2 Backend Environment Configuration
# ============================================
# Copy this file to .env and update values
# NEVER commit .env to version control!
# ============================================

# --------------------------------------------
# Application Settings
# --------------------------------------------
APP_NAME=CUIN v2 Control Plane
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=INFO

# --------------------------------------------
# API Server
# --------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# --------------------------------------------
# Security
# --------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-this-to-a-secure-random-string-in-production

# CORS - Comma-separated origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --------------------------------------------
# PostgreSQL Database
# --------------------------------------------
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://cuin:cuin_secret@localhost:5432/cuin_db

# Connection pool settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# --------------------------------------------
# Neo4j Graph Database
# --------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_secret

# --------------------------------------------
# Referee Agent (LLM)
# --------------------------------------------
LLM_ENABLED=false
LLM_MODEL_PATH=/path/to/local/llm
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.3

# --------------------------------------------
# Blocking Configuration
# --------------------------------------------
BLOCKING_MAX_BLOCK_SIZE=200
BLOCKING_MAX_KEYS_PER_RECORD=50
BLOCKING_SUPPRESS_FREQUENCY_PCT=5.0

# --------------------------------------------
# Scoring Thresholds
# --------------------------------------------
THRESHOLD_AUTO_LINK=0.92
THRESHOLD_REVIEW_MIN=0.55
THRESHOLD_REFEREE_MIN=0.45
THRESHOLD_REFEREE_MAX=0.70

# --------------------------------------------
# File Paths
# --------------------------------------------
# Sample data for testing
SAMPLE_CSV_PATH=/home/arnob/Downloads/challenging_er_200.csv

# Policy files
POLICY_DIR=./policies

# --------------------------------------------
# Run Configuration
# --------------------------------------------
# Maximum candidates per run (safety limit)
MAX_CANDIDATES_PER_RUN=1000000

# Maximum records for FULL mode warning
FULL_MODE_RECORD_THRESHOLD=100000
